<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BenjaminAdamApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BenjaminAdamApp"
    Shell.FlyoutBehavior="Disabled"
    
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarForegroundColor="#4A2E1B" 
    Shell.TabBarTitleColor="#4A2E1B"
    Shell.TabBarUnselectedColor="#B0B0B0">

    <TabBar>
        <Tab Title="Accueil" Icon="home_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <Tab Title="Découvrir" Icon="list_icon.png">
            <ShellContent Route="listpage" ContentTemplate="{DataTemplate local:ListPage}" />
        </Tab>

        <Tab Title="Ajouter" Icon="add_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:AddPage}" />
        </Tab>

        <Tab Title="Plus" Icon="star_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:ExtraPage}" />
        </Tab>
    </TabBar>
</Shell>