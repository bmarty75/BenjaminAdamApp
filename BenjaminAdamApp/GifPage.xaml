<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BenjaminAdamApp.GifPage"
             Title="Animation GIF">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">
            
            <Label Text="Voici notre composant animé !" 
                   FontSize="24" 
                   HorizontalOptions="Center" 
                   FontAttributes="Bold"
                   TextColor="#4A2E1B"/>

            <Image Source="https://media3.giphy.com/media/v1.Y2lkPTc5MGI3NjExamhnZ3IzdzY2NzZrY2E4MmtlZ3NmOWF1bm9oZjhiY3RiaXR4Zmx4MyZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/bIEzoZX0qJaG6s6frc/giphy.gif"
                   IsAnimationPlaying="True"
                   HeightRequest="300"
                   HorizontalOptions="Center" />

            <Button Text="Retour à l'accueil"
                    Clicked="OnBackButtonClicked"
                    BackgroundColor="#4A2E1B"
                    TextColor="White"
                    HorizontalOptions="Center"
                    Margin="0,20,0,0"
                    Padding="20,10"
                    CornerRadius="10" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
