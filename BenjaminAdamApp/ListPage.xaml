<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BenjaminAdamApp"
             x:Class="BenjaminAdamApp.ListPage"
             Title="Découvrir">

    <Grid RowDefinitions="Auto, *">
        <Label Text="La carte BenAdam" 
               FontSize="28" FontAttributes="Bold" Padding="20" 
               HorizontalOptions="Center" TextColor="#4A2E1B" />

        <ActivityIndicator Grid.Row="1" x:Name="LoadingIndicator" 
                           IsRunning="True" IsVisible="True"
                           VerticalOptions="Center" HorizontalOptions="Center" Color="#4A2E1B" />

        <CollectionView Grid.Row="1" x:Name="BeerCollection" Margin="10" IsVisible="False">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:Beer">
                    <Border Margin="5,10" Padding="10" StrokeShape="RoundRectangle 15" StrokeThickness="1">
                        <Border.Stroke>
                            <SolidColorBrush Color="#E0E0E0" />
                        </Border.Stroke>
                        
                        <HorizontalStackLayout Spacing="15">
                            <Border StrokeShape="RoundRectangle 10" HeightRequest="100" WidthRequest="100">
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                            </Border>

                            <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="20" TextColor="#4A2E1B" />
                                <Label Text="{Binding Description}" FontSize="14" LineBreakMode="WordWrap" WidthRequest="200" TextColor="Gray" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>